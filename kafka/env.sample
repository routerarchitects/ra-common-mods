# Kafka Configuration Environment Variables
# ==========================================
# This file contains all available environment variables for configuring the Kafka client.
# Copy this file to `.env` and update with your actual values.

# ==========================================
# Core Kafka Configuration
# ==========================================

# Comma-separated list of Kafka broker addresses
# Example: "localhost:9092" or "broker1:9092,broker2:9092,broker3:9092"
KAFKA_BROKERS=localhost:9092

# Client ID identifies this client in Kafka logs
# Default: "ra-kafka-client"
KAFKA_CLIENT_ID=my-service-client

# ==========================================
# SASL Authentication
# ==========================================

# Enable SASL authentication
# Default: false
KAFKA_AUTH_SASL_ENABLED=false

# SASL mechanism: PLAIN, SCRAM-SHA-256, or SCRAM-SHA-512
# Default: PLAIN
KAFKA_AUTH_SASL_MECHANISM=SCRAM-SHA-256

# SASL username
KAFKA_AUTH_SASL_USERNAME=your-username

# SASL password
KAFKA_AUTH_SASL_PASSWORD=your-password

# ==========================================
# TLS Configuration
# ==========================================

# Enable TLS encryption
# Default: false
KAFKA_AUTH_TLS_ENABLED=true

# Skip certificate verification (for testing only - NOT for production)
# Default: false
KAFKA_AUTH_TLS_INSECURE_SKIP_VERIFY=false

# Path to client certificate file
KAFKA_AUTH_TLS_CERT_FILE=/path/to/client.crt

# Path to client key file
KAFKA_AUTH_TLS_KEY_FILE=/path/to/client.key

# Path to CA certificate file
KAFKA_AUTH_TLS_CA_FILE=/path/to/ca.crt

# ==========================================
# Consumer Configuration
# ==========================================

# Consumer group ID
KAFKA_CONSUMER_GROUP_ID=my-consumer-group

# Comma-separated list of topics to subscribe to
# Example: "topic1" or "topic1,topic2,topic3"
KAFKA_CONSUMER_TOPICS=my-topic

# Initial offset position: "oldest" or "newest"
# Default: newest
KAFKA_CONSUMER_INITIAL_OFFSET=newest

# Consumer group session timeout
# Default: 10s
KAFKA_CONSUMER_SESSION_TIMEOUT=10s

# Heartbeat interval for consumer group coordination
# Default: 3s
KAFKA_CONSUMER_HEARTBEAT_INTERVAL=3s

# Maximum time for processing a batch of messages
# Default: 30s
KAFKA_CONSUMER_MAX_PROCESSING_TIME=30s

# Commit mode:
#   > 0 : auto-commit at this interval
# COMMIT_INTERVAL must be greater than zero.
# SubscribeOptions.AutoCommit override:
#   -1 per-message sync commit, 0 inherit COMMIT_INTERVAL, >0 interval commit
# Default: 5s
KAFKA_CONSUMER_COMMIT_INTERVAL=5s

# ==========================================
# Producer Configuration
# ==========================================

# Maximum message size in bytes
# Default: 1000000 (1MB)
KAFKA_PRODUCER_MAX_MESSAGE_BYTES=1000000

# Required acknowledgements: 0 (no response), 1 (leader only), -1 (all in-sync replicas)
# Default: -1
KAFKA_PRODUCER_REQUIRED_ACKS=-1

# Timeout for produce requests
# Default: 10s
KAFKA_PRODUCER_TIMEOUT=10s

# Compression codec: none, gzip, snappy, lz4, or zstd
# Default: snappy
KAFKA_PRODUCER_COMPRESSION=snappy

# Enable idempotent producer (ensures exactly-once semantics)
# Default: true
KAFKA_PRODUCER_IDEMPOTENT=true

# Maximum number of retries for failed produce requests
# Default: 3
KAFKA_PRODUCER_MAX_RETRIES=3

# Backoff duration between retries
# Default: 100ms
KAFKA_PRODUCER_RETRY_BACKOFF=100ms
